&HEAD CHID='TUS_facade_2-1-2-3'/

&TIME T_END=2700.0  /

&CATF OTHER_FILES='TUS_MATL.txt', 'TUS_static_geom.txt', 'TUS_devices.txt' /

&RAMP ID='fireramp', T=   0.0, F=0.000 /
