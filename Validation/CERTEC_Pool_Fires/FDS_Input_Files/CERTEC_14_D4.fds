&HEAD CHID='CERTEC_14_D4', TITLE='Centre for Studies on Technological Risk diesel pool fire experiment' /

&TIME T_END=60. /

&MESH IJK=40,40,40, XB=-4.0,0.0,-4.0,0.0,0.0,4.0, MULT_ID='mesh' /
&MULT ID='mesh', DX=4., DY=4., DZ=4., I_UPPER=5, J_UPPER=1, K_UPPER=2 /

&MESH IJK=60,10,30, XB=-4.0,20.0,-8.0,-4.0, 0.0,12.0 /
&MESH IJK=60,10,30, XB=-4.0,20.0, 4.0, 8.0, 0.0,12.0 /
&MESH IJK=60,40,10, XB=-4.0,20.0,-8.0, 8.0,12.0,16.0 /
&MESH IJK=10,40,40, XB=-8.0,-4.0,-8.0, 8.0, 0.0,16.0 /
&MESH IJK=10,40,40, XB=-12.0,-8.0,-8.0, 8.0, 0.0,16.0 /

&WIND SPEED=0.43, L=-350, Z_REF=10., Z_0=0.0002, RAMP_SPEED_T='spd', RAMP_DIRECTION_T='dir' /

&CATF OTHER_FILES='wind.txt' /

&VENT MB='XMIN', SURF_ID='OPEN' /
&VENT MB='XMAX', SURF_ID='OPEN' /
&VENT MB='YMIN', SURF_ID='OPEN' /
&VENT MB='YMAX', SURF_ID='OPEN' /
&VENT MB='ZMAX', SURF_ID='OPEN' /

&MISC TMPA=20, HUMIDITY=70 /

&REAC FUEL ='DIESEL'
      C = 2
      H = 4
      SOOT_YIELD = 0.01
      CO_YIELD = 0.001
      RADIATIVE_FRACTION=0.192 /

&RADI NUMBER_RADIATION_ANGLES=600, PATH_LENGTH=10 /

&SURF ID='POOL', MLRPUA=0.058, TMP_FRONT=100., COLOR='BLUE' /

&SURF ID='PAN', COLOR='BLACK' /

&DUMP DT_HRR=1., DT_DEVC=1. /

&PROP ID='TC', EMISSIVITY=0.9, DIAMETER=0.001 /

&DEVC ID='TC', Z_ID='z_TC', XB=0.01,0.01,0.01,0.01,2.84,11.01, POINTS=5, STATISTICS_START=10., 
      QUANTITY='THERMOCOUPLE', PROP_ID='TC', POINTS_ARRAY_Z=2.84,3.96,5.53,6.96,11.01 /
&DEVC ID='HF_wide', XYZ=11.83,2.0,0.1, STATISTICS_START=10., TEMPORAL_STATISTIC='RUNNING AVERAGE', 
      QUANTITY='RADIATIVE HEAT FLUX GAS', ORIENTATION=-11.83,-2.0,0.0 /

&DEVC XBP=0.0,0.0,0.0,0.0,0.05,11.95, QUANTITY='HRRPUV', SPATIAL_STATISTIC='VOLUME INTEGRAL', DX=4., DY=4., DZ=0.05, 
      POINTS=120, Z_ID='z_HRRPUL', ID='HRRPUL', STATISTICS_START=10. /
&DEVC XB=-4.0,4.0,-4.0,4.0,4.9,5.0, QUANTITY='TEMPERATURE', SPATIAL_STATISTIC='MAXLOC X', ID='x_max' /
&DEVC XB=-4.0,4.0,-4.0,4.0,4.9,5.0, QUANTITY='TEMPERATURE', SPATIAL_STATISTIC='MAXLOC Y', ID='y_max' /
&CTRL ID='x2', FUNCTION_TYPE='POWER', INPUT_ID='x_max','CONSTANT', CONSTANT=2 /
&CTRL ID='y2', FUNCTION_TYPE='POWER', INPUT_ID='y_max','CONSTANT', CONSTANT=2 /
&CTRL ID='d2', FUNCTION_TYPE='SUM', INPUT_ID='x2','y2' /
&CTRL ID='d',  FUNCTION_TYPE='POWER', INPUT_ID='d2','CONSTANT', CONSTANT=0.5 /
&CTRL ID='H', FUNCTION_TYPE='PERCENTILE', INPUT_ID='HRRPUL', PERCENTILE=0.97 /
&CTRL ID='d/5', FUNCTION_TYPE='DIVIDE', INPUT_ID='d','CONSTANT', CONSTANT=5. /
&CTRL ID='tilt_rad', FUNCTION_TYPE='ATAN', INPUT_ID='d/5' /
&CTRL ID='tilt_deg', FUNCTION_TYPE='MULTIPLY', INPUT_ID='tilt_rad','CONSTANT', CONSTANT=57.296 /
&CTRL ID='cos_theta', FUNCTION_TYPE='COS', INPUT_ID='tilt_rad' /
&CTRL ID='L', FUNCTION_TYPE='DIVIDE', INPUT_ID='H','cos_theta' /
&DEVC ID='L_F',  XYZ=0,0,0, QUANTITY='CONTROL VALUE', TEMPORAL_STATISTIC='RUNNING AVERAGE', STATISTICS_START=10, CTRL_ID='L', UNITS='m' /
&DEVC ID='tilt', XYZ=0,0,0, QUANTITY='CONTROL VALUE', TEMPORAL_STATISTIC='RUNNING AVERAGE', STATISTICS_START=10, CTRL_ID='tilt_deg', UNITS='deg' /

&SLCF PBY=0.1, QUANTITY='VELOCITY',             VECTOR=T /
&SLCF PBY=0.1, QUANTITY='TEMPERATURE',          CELL_CENTERED=T /
&SLCF PBY=0.1, QUANTITY='HRRPUV',               CELL_CENTERED=T /
&SLCF PBY=0.1, QUANTITY='INTEGRATED INTENSITY', CELL_CENTERED=T /
&SLCF PBZ=0.1, QUANTITY='INTEGRATED INTENSITY', CELL_CENTERED=T /

&OBST XB= -0.500, -0.400, -2.100, -2.000,  0.000,  0.200, SURF_ID='PAN' /
&OBST XB= -0.400, -0.300, -2.100, -2.000,  0.000,  0.200, SURF_ID='PAN' /
