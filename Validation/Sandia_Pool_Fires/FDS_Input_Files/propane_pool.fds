&HEAD CHID='propane_pool', TITLE='Sandia 5 m propane pool fire' /

&MESH IJK=50,50,72, XB=-10,0,-10,0,-0.3,14.1, MULT_ID='mesh1' /
&MULT ID='mesh1', DX=10, DY=10, DZ=14.4, I_UPPER=1, J_UPPER=1, K_UPPER=1 /

&MESH IJK=50,50,72, XB=-30,-10,-30,-10,-0.3,28.5, MULT_ID='mesh2' /
&MULT ID='mesh2', DX=20, DY=20, I_UPPER=2, I_LOWER_SKIP=1, I_UPPER_SKIP=1, J_UPPER=2, J_LOWER_SKIP=1, J_UPPER_SKIP=1 /

&TIME T_END=40. /

&MISC TMPA=1., P_INF=81186, HUMIDITY=19. /

&RADI NUMBER_RADIATION_ANGLES=600, PATH_LENGTH=30. /

&WIND SPEED=2.8, DIRECTION=279 /

&REAC FUEL='PROPANE', SOOT_YIELD=0.005, RADIATIVE_FRACTION=0.35 /

&SURF ID='PAN', MLRPUA=0.112, COLOR='LIGHT BLUE' / 

&SURF ID='GROUND', ROUGHNESS=0.1, DEFAULT=T, COLOR='TAN' /

&VENT MB='XMIN', SURF_ID='OPEN' /
&VENT MB='XMAX', SURF_ID='OPEN' /
&VENT MB='YMIN', SURF_ID='OPEN' /
&VENT MB='YMAX', SURF_ID='OPEN' /
&VENT MB='ZMAX', SURF_ID='OPEN' /

&CATF OTHER_FILES='pool_devices.txt', 'pan.txt' /

&DEVC ID='HRRPUL_1', XBP=0.0,0.0,0.0,0.0,0.3,28.3, QUANTITY='HRRPUV', SPATIAL_STATISTIC='VOLUME INTEGRAL', DX=20., DY=20., DZ=0.2, POINTS=71, Z_ID='z_HRRPUL',    STATISTICS_START=10., STATISTICS_END=40. /

&DEVC ID='x_max_1', XB=-10.0,10.0,-10.0,10.0,13.9,14.1, QUANTITY='TEMPERATURE', SPATIAL_STATISTIC='MAXLOC X', STATISTICS_START=10., STATISTICS_END=40. /
&DEVC ID='y_max_1', XB=-10.0,10.0,-10.0,10.0,13.9,14.1, QUANTITY='TEMPERATURE', SPATIAL_STATISTIC='MAXLOC Y', STATISTICS_START=10., STATISTICS_END=40. /
&CTRL ID='x/14_1', FUNCTION_TYPE='DIVIDE', INPUT_ID='x_max_1','CONSTANT', CONSTANT=14. /
&CTRL ID='y/14_1', FUNCTION_TYPE='DIVIDE', INPUT_ID='y_max_1','CONSTANT', CONSTANT=14. /
&CTRL ID='tilt_rad_s_1', FUNCTION_TYPE='ATAN', INPUT_ID='x/14_1' /
&CTRL ID='tilt_rad_w_1', FUNCTION_TYPE='ATAN', INPUT_ID='y/14_1' /
&CTRL ID='tilt_deg_s_1', FUNCTION_TYPE='MULTIPLY', INPUT_ID='tilt_rad_s_1','CONSTANT', CONSTANT= 57.296 /
&CTRL ID='tilt_deg_w_1', FUNCTION_TYPE='MULTIPLY', INPUT_ID='tilt_rad_w_1','CONSTANT', CONSTANT=-57.296 /
&CTRL ID='cos_theta_s_1', FUNCTION_TYPE='COS', INPUT_ID='tilt_rad_s_1' /
&CTRL ID='cos_theta_w_1', FUNCTION_TYPE='COS', INPUT_ID='tilt_rad_w_1' /
&CTRL ID='H_1', FUNCTION_TYPE='PERCENTILE', INPUT_ID='HRRPUL_1', PERCENTILE=0.97 /
&CTRL ID='L_s_1', FUNCTION_TYPE='DIVIDE', INPUT_ID='H_1','cos_theta_s_1' /
&CTRL ID='L_w_1', FUNCTION_TYPE='DIVIDE', INPUT_ID='H_1','cos_theta_w_1' /
&DEVC ID='L_F_s_1',  XYZ=0,0,0, QUANTITY='CONTROL VALUE', TEMPORAL_STATISTIC='RUNNING AVERAGE', STATISTICS_START=10, STATISTICS_END=40., CTRL_ID='L_s_1', UNITS='m' /
&DEVC ID='L_F_w_1',  XYZ=0,0,0, QUANTITY='CONTROL VALUE', TEMPORAL_STATISTIC='RUNNING AVERAGE', STATISTICS_START=10, STATISTICS_END=40., CTRL_ID='L_w_1', UNITS='m' /
&DEVC ID='tilt_s_1', XYZ=0,0,0, QUANTITY='CONTROL VALUE', TEMPORAL_STATISTIC='RUNNING AVERAGE', STATISTICS_START=10, STATISTICS_END=40., CTRL_ID='tilt_deg_s_1', UNITS='deg' /
&DEVC ID='tilt_w_1', XYZ=0,0,0, QUANTITY='CONTROL VALUE', TEMPORAL_STATISTIC='RUNNING AVERAGE', STATISTICS_START=10, STATISTICS_END=40., CTRL_ID='tilt_deg_w_1', UNITS='deg' /

&SLCF PBZ=1.25, QUANTITY='INTEGRATED INTENSITY', CELL_CENTERED=T /
&SLCF PBY=0.01, QUANTITY='INTEGRATED INTENSITY', CELL_CENTERED=T /
&SLCF PBY=0.01, QUANTITY='TEMPERATURE', CELL_CENTERED=T /
&SLCF PBY=0.01, QUANTITY='TEMPERATURE', VECTOR=T /

&TAIL /
