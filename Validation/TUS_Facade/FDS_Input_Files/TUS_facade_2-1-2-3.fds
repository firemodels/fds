 VENT XB=2.2,2.8,4.0,4.0,0.4,0.9, ID='Inside', SURF_ID='WALL', COLOR='GRAY 20' /
 VENT XB=3.1,3.7,4.0,4.0,0.4,0.9, ID='Inside', SURF_ID='WALL', COLOR='GRAY 20' /

 VENT XB=0.3,0.9,4.0,4.0,0.4,0.9, ID='Outside', SURF_ID='WALL', COLOR='GRAY 20' /  Leakage
 VENT XB=1.2,1.8,4.0,4.0,0.4,0.9, ID='Outside', SURF_ID='WALL', COLOR='GRAY 20' /  
 VENT XB=2.2,2.8,4.0,4.0,0.4,0.9, ID='Outside', SURF_ID='WALL', COLOR='GRAY 20' /
 VENT XB=3.1,3.7,4.0,4.0,0.4,0.9, ID='Outside', SURF_ID='WALL', COLOR='GRAY 20' /

&HOLE XB=0.3,0.9,3.9,4.2,0.4,0.5 /  Leakage
