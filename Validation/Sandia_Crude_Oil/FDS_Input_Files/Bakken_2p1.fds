&HEAD CHID='Bakken_2p1', TITLE='Sandia Crude Oil Indoor Test' /

&TIME T_END=30. /

&MESH IJK=40,50,25, XB=-2.0,2.0,-2.5,2.5,0.0,2.5, MULT_ID='mesh' /
&MULT ID='mesh', DX=4, DZ=2.5, I_UPPER=2, K_UPPER=3 /

&VENT MB='XMIN', SURF_ID='OPEN' /
&VENT MB='XMAX', SURF_ID='OPEN' /
&VENT MB='YMIN', SURF_ID='OPEN' /
&VENT MB='YMAX', SURF_ID='OPEN' /
&VENT MB='ZMAX', SURF_ID='OPEN' /

&MISC TMPA=11, P_INF=84998, HUMIDITY=26 /

&REAC FUEL ='N-HEPTANE'
      SOOT_YIELD = 0.01
      CO_YIELD = 0.001
      HEAT_OF_COMBUSTION = 46800.
      RADIATIVE_FRACTION=0.5 /

&RADI NUMBER_RADIATION_ANGLES=600, PATH_LENGTH=10 /

&VENT XB=-2.0,2.0,-2.0,2.0,0,0, XYZ=0,0,0, RADIUS=1.0, SURF_ID='BURNER' /

&SURF ID='BURNER', MLRPUA=0.03, TMP_FRONT=21., COLOR='BLUE' /

&SURF ID='PAN', COLOR='BLACK' /

&DUMP DT_HRR=1., DT_DEVC=1. /

&PROP ID='TC', EMISSIVITY=0.9, DIAMETER=0.001016 /

&DEVC ID='TC', Z_ID='z_TC', XB=0.10,0.10,0.1,0.1,0.1,7.9, POINTS=9, STATISTICS_START=10., QUANTITY='THERMOCOUPLE', PROP_ID='TC',
      POINTS_ARRAY_Z=1.5,2.0,2.5,3.0,3.5,4.0,4.5,5.0,5.5 /
&DEVC ID='HF_wide',   Z_ID='z_HF', XB=9.10,9.10,0.91,0.91,0.1,7.9, 
      POINTS=6, STATISTICS_START=10., QUANTITY='RADIATIVE HEAT FLUX GAS', ORIENTATION=-0.995,-0.100,0.0
      POINTS_ARRAY_Z=0.5,1.0,1.5,2.0,3.0,4.0 /
&DEVC ID='HF_narrow', HIDE_COORDINATES=T, XB=9.10,9.10,0.91,0.91,0.1,7.9, 
      POINTS=6, STATISTICS_START=10., QUANTITY='RADIANCE', ORIENTATION=-0.995,-0.100,0.1, CONVERSION_FACTOR=3.14159, UNITS='kW/m2'
      POINTS_ARRAY_Z=0.5,1.0,1.5,2.0,3.0,4.0 /
&DEVC XB=0.0,0.0,0.0,0.0,0.05,9.95, QUANTITY='HRRPUV', DX=2.0, DY=2.5, DZ=0.05, SPATIAL_STATISTIC='VOLUME INTEGRAL', POINTS=100, Z_ID='z', ID='HRR', STATISTICS_START=10. /
&CTRL ID='pct', FUNCTION_TYPE='PERCENTILE', INPUT_ID='HRR', PERCENTILE=0.97 /
&DEVC ID='L_F', XYZ=0,0,0, QUANTITY='CONTROL VALUE', TEMPORAL_STATISTIC='RUNNING AVERAGE', STATISTICS_START=10, CTRL_ID='pct', UNITS='m' /

&SLCF PBY=0.1, QUANTITY='TEMPERATURE',          CELL_CENTERED=T /
&SLCF PBY=0.1, QUANTITY='HRRPUV',               CELL_CENTERED=T /
&SLCF PBY=0.1, QUANTITY='INTEGRATED INTENSITY', CELL_CENTERED=T /
&SLCF PBZ=2.1, QUANTITY='INTEGRATED INTENSITY', CELL_CENTERED=T /

&TAIL /
