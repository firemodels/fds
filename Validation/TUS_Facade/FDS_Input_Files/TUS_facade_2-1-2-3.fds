Window
&HOLE XB=1.0,3.0,-0.2,0.1, 0.5,0.7                   / Window H = 0.2 m for test 2-1
&HOLE XB=1.0,3.0,-0.2,0.1, 0.7,1.0, DEVC_ID='TIMER'  / Window H = 0.5 m for test 2-2
&HOLE XB=1.0,3.0,-0.2,0.1, 1.0,1.5, DEVC_ID='TIMER2' / Window H = 1.0 m for test 2-3

&DEVC QUANTITY='TIME', ID='TIMER',  SETPOINT=400.,  XYZ=0.0,0.0,0.0, INITIAL_STATE=F /
&DEVC QUANTITY='TIME', ID='TIMER2', SETPOINT=1600., XYZ=0.0,0.0,0.0, INITIAL_STATE=F /

 HVAC ID='Leakage', TYPE_ID='LEAK', VENT_ID='Inside', VENT2_ID='Outside', AREA=0.01 /

 VENT XB=0.3,0.9,4.0,4.0,0.4,0.9, ID='Inside', SURF_ID='WALL', COLOR='GRAY 20' /  Leakage
